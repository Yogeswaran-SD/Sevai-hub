{
  "services": {
    "backend": {
      "serviceId": "backend",
      "rootDirectory": "backend",
      "buildCommand": "pip install -r requirements.txt",
      "startCommand": "uvicorn app.main:app --host 0.0.0.0 --port $PORT",
      "dockerfile": "backend/Dockerfile",
      "port": 8000,
      "variables": {
        "POSTGRES_HOST": "${{ services.postgres.host }}",
        "POSTGRES_PORT": "${{ services.postgres.port }}",
        "POSTGRES_USER": "postgres",
        "POSTGRES_PASSWORD": "${{ services.postgres.password }}",
        "POSTGRES_DB": "sevaihub",
        "REDIS_URL": "redis://${{ services.redis.host }}:${{ services.redis.port }}",
        "SECRET_KEY": "your-secret-key-min-32-chars",
        "ALGORITHM": "HS256",
        "ACCESS_TOKEN_EXPIRE_MINUTES": "1440",
        "ENVIRONMENT": "production"
      }
    },
    "frontend": {
      "serviceId": "frontend",
      "rootDirectory": "frontend",
      "buildCommand": "npm install && npm run build",
      "startCommand": "npm run preview",
      "dockerfile": "frontend/Dockerfile",
      "port": 3000,
      "variables": {
        "VITE_API_URL": "${{ services.backend.url }}"
      }
    },
    "postgres": {
      "image": "postgis/postgis:16-3.4",
      "variables": {
        "POSTGRES_USER": "postgres",
        "POSTGRES_PASSWORD": "postgres-secure-password",
        "POSTGRES_DB": "sevaihub"
      }
    },
    "redis": {
      "image": "redis:7-alpine",
      "variables": {}
    }
  }
}
