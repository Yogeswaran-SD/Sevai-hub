# Frontend .dockerignore - Exclude unnecessary files from Docker build context

# Node modules (will be installed inside container)
node_modules

# Environment
.env
.env.local
.env.*.local
.env.*.example

# Build artifacts
dist
dist-ssr
*.local

# Development
.vscode/
.idea/
.DS_Store
*.swp
*.swo

# Git
.git
.gitignore
.gitattributes

# Package manager locks (build from fresh)
# Uncomment if rebuilding dependencies each time is desired
# pnpm-lock.yaml
# package-lock.json
# yarn.lock

# Testing
.vitest
coverage/

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# Documentation
*.md
docs/

# OS files
Thumbs.db
.DS_Store
