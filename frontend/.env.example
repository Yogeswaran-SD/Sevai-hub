# Sevai Hub - Frontend Environment Configuration
# Copy this file to `.env.development.local` or `.env.production.local` as needed
# NEVER commit real API URLs with authentication tokens to version control

# ============================================================================
# API Configuration
# ============================================================================
# Backend API Base URL (without trailing slash)
VITE_API_URL=http://localhost:8000

# ============================================================================
# Application Settings
# ============================================================================
# Application environment
VITE_ENVIRONMENT=development
# Options: development, staging, production

# ============================================================================
# Feature Flags (Optional)
# ============================================================================
VITE_ENABLE_DEMO_MODE=true
VITE_ENABLE_DEBUG_LOGS=false

# ============================================================================
# Analytics & Monitoring (Optional)
# ============================================================================
# If using Sentry for error tracking
# VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
