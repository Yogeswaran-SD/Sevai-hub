# Sevai Hub - Docker Deployment Environment Configuration
# Copy this file to `.env` in the root directory for docker-compose to use
# NEVER commit real secrets to version control!

# ============================================================================
# Database Configuration
# ============================================================================
DB_PASSWORD=your_secure_postgres_password_change_me
POSTGRES_INITDB_ARGS=-c max_connections=200

# ============================================================================
# Backend (FastAPI) Configuration
# ============================================================================
SECRET_KEY=your_secure_secret_key_min_32_chars_change_in_prod
ENVIRONMENT=production

# Admin credentials (MUST change for production)
ADMIN_MOBILE=9999999999
ADMIN_AADHAAR=123456789012
ADMIN_SECRET_KEY=your_admin_secret_key_change
ADMIN_PASSWORD_HASH=$2b$12$R9h7cIPz0gi.URNNX3kh2OPST9GfGQIm0jAGjfNcXt8mS5jSrqMSC

# CORS Origins (adjust for your domain)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Debug mode (MUST be False in production!)
DEBUG=False

# ============================================================================
# Frontend (React/Vite) Configuration
# ============================================================================
VITE_API_URL=http://localhost:8000
VITE_ENVIRONMENT=production
