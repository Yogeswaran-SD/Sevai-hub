# Sevai Hub - Backend Environment Configuration
# Copy this file to `.env` (git-ignored) and fill in real values
# NEVER commit `.env` with real passwords to version control

# ============================================================================
# Application Environment
# ============================================================================
ENVIRONMENT=development
# Options: development, staging, production (affects validation and logging)

# ============================================================================
# Database Configuration (PostgreSQL with PostGIS)
# ============================================================================
DATABASE_URL=postgresql://postgres:your_secure_password@postgres:5432/sevaihub
# Format: postgresql://username:password@hostname:port/database_name
# Note: Must have PostGIS extension enabled: CREATE EXTENSION postgis;

# ============================================================================
# JWT / Authentication Security (REQUIRED)
# ============================================================================
# Generate a secure SECRET_KEY with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your_securely_generated_secret_key_min_32_chars_do_not_use_default
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============================================================================
# Admin Credentials (HIGH SECURITY)
# ============================================================================
# Admin Aadhaar ID
ADMIN_AADHAAR=123456789012

# Admin Mobile Number
ADMIN_MOBILE=9999999999

# Admin Secret Key (for special admin operations)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_SECRET_KEY=your_admin_secret_key_here

# Admin Password HASH (BCRYPT ONLY - use script to generate)
# Generate hash with: python -c "from passlib.context import CryptContext; pwd_context = CryptContext(schemes=['bcrypt']); print(pwd_context.hash('YourPassword123!'))"
# NEVER use plaintext password here!
ADMIN_PASSWORD_HASH=$2b$12$R9h7cIPz0gi.URNNX3kh2OPST9GfGQIm0jAGjfNcXt8mS5jSrqMSC

# ============================================================================
# CORS Configuration
# ============================================================================
# Comma-separated list of allowed origins for frontend
# For production, set to your domain only
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# Example for production:
# CORS_ORIGINS=https://app.sevaihub.com,https://www.sevaihub.com

# ============================================================================
# Debug & Testing (NEVER enabled in production!)
# ============================================================================
DEBUG=False
TESTING=False
ALLOW_ORIGINS_ALL=False

# ============================================================================
# Logging (Optional)
# ============================================================================
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ============================================================================
# Redis Cache Configuration
# ============================================================================
# Redis connection string for caching service data
# Format: redis://[password@]hostname[:port][/database]
REDIS_URL=redis://redis:6379

# ============================================================================
# MinIO Object Storage Configuration
# ============================================================================
# MinIO endpoint URL (http for development, https for production)
MINIO_URL=http://minio:9000

# MinIO console access credentials (change from defaults in production!)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123

# Default S3 bucket for storing files (profile pictures, documents, etc.)
MINIO_BUCKET=sevaihub

# ============================================================================
# Email/SMTP Configuration (Optional - leave empty to disable)
# ============================================================================
# SMTP server for sending emails (e.g., Gmail, SendGrid, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# SMTP authentication credentials
# For Gmail: use your email and generate an App Password (not your main password)
# See: https://support.google.com/accounts/answer/185833
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Email sender information
EMAILS_FROM_EMAIL=noreply@sevaihub.com
# EMAILS_FROM_NAME=Sevai Hub (optional)

# ============================================================================
# SMS/Twilio Configuration (Optional - leave empty to disable)
# ============================================================================
# Get these credentials from https://www.twilio.com/console

# Twilio Account SID (found in Account Settings)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio Auth Token (found in Account Settings)
TWILIO_AUTH_TOKEN=your-auth-token-here

# Twilio phone number to send SMS from (E.164 format with +)
# Example: +12025551234
TWILIO_PHONE_NUMBER=+11234567890

